<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
              xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
              name="ReporteVentasEmpleados"
              pageWidth="842" pageHeight="595"
              orientation="Landscape"
              columnWidth="802"
              leftMargin="20" rightMargin="20"
              topMargin="20" bottomMargin="20"
              uuid="b82c1a04-91e3-4d5a-a2f7-38514957d221">

    <property name="com.jaspersoft.studio.data.sql.tables" value=""/>
    <property name="com.jaspersoft.studio.data.defaultdataadapter" value="BaseZoo"/>

    <style name="encabezado_col" fontName="DejaVu Sans" fontSize="11" isBold="true" forecolor="#FFFFFF"/>
    <style name="dato_texto"     fontName="DejaVu Sans" fontSize="11"               forecolor="#2D3A2E"/>
    <style name="dato_numero"    fontName="DejaVu Sans" fontSize="11" isBold="true" forecolor="#1B4332"/>
    <style name="footer_texto"   fontName="DejaVu Sans" fontSize="9"                forecolor="#74857A"/>

    <queryString language="SQL">
        <![CDATA[SELECT
    e.nombre_empleado,
    e.apellido,
    e.rol,
    COUNT(v.id)      AS total_ventas,
    SUM(v.subtotal)  AS total_ingresos
FROM public.visita v
JOIN public.empleado e ON v.idempleado = e.id
GROUP BY e.id, e.nombre_empleado, e.apellido, e.rol
ORDER BY total_ingresos DESC]]>
    </queryString>

    <field name="nombre_empleado" class="java.lang.String"/>
    <field name="apellido"        class="java.lang.String"/>
    <field name="rol"             class="java.lang.String"/>
    <field name="total_ventas"    class="java.lang.Long"/>
    <field name="total_ingresos"  class="java.lang.Double"/>

    <variable name="GRAND_TOTAL" class="java.lang.Double" calculation="Sum">
        <variableExpression><![CDATA[$F{total_ingresos}]]></variableExpression>
    </variable>
    <variable name="GRAND_VENTAS" class="java.lang.Long" calculation="Sum">
        <variableExpression><![CDATA[$F{total_ventas}]]></variableExpression>
    </variable>

    <background>
        <band splitType="Stretch"/>
    </background>

    <!-- ══════════════ TITLE ══════════════ -->
    <title>
        <band height="90" splitType="Stretch">
            <!-- Fondo azul oscuro -->
            <rectangle>
                <reportElement x="0" y="0" width="802" height="90" backcolor="#1A3A5C" forecolor="#1A3A5C" uuid="c1a2b3d4-e5f6-7890-abcd-ef1234567801"/>
                <graphicElement><pen lineWidth="0"/></graphicElement>
            </rectangle>
            <!-- Acento lateral azul claro -->
            <rectangle>
                <reportElement x="0" y="0" width="5" height="90" backcolor="#4A90D9" forecolor="#4A90D9" uuid="c1a2b3d4-e5f6-7890-abcd-ef1234567802"/>
                <graphicElement><pen lineWidth="0"/></graphicElement>
            </rectangle>
            <!-- Título -->
            <staticText>
                <reportElement x="18" y="10" width="600" height="38" forecolor="#FFFFFF" uuid="c1a2b3d4-e5f6-7890-abcd-ef1234567803"/>
                <textElement verticalAlignment="Middle">
                    <font fontName="DejaVu Sans" size="26" isBold="true"/>
                </textElement>
                <text><![CDATA[WILD ZOO MK]]></text>
            </staticText>
            <!-- Subtítulo -->
            <staticText>
                <reportElement x="18" y="52" width="600" height="22" forecolor="#A8C8F0" uuid="c1a2b3d4-e5f6-7890-abcd-ef1234567804"/>
                <textElement verticalAlignment="Middle">
                    <font fontName="DejaVu Sans" size="12"/>
                </textElement>
                <text><![CDATA[Reporte de ventas por empleado]]></text>
            </staticText>
            <!-- Fecha -->
            <textField>
                <reportElement x="560" y="36" width="240" height="18" forecolor="#A8C8F0" uuid="c1a2b3d4-e5f6-7890-abcd-ef1234567805"/>
                <textElement textAlignment="Right" verticalAlignment="Middle">
                    <font fontName="DejaVu Sans" size="9"/>
                </textElement>
                <textFieldExpression><![CDATA["Generado: " + new java.text.SimpleDateFormat("dd/MM/yyyy h:mma", java.util.Locale.ENGLISH).format(new java.util.Date())]]></textFieldExpression>
            </textField>
        </band>
    </title>

    <pageHeader>
        <band height="8" splitType="Stretch"/>
    </pageHeader>

