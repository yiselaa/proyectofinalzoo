    <!-- ══════════════ SUMMARY: GRÁFICO DE BARRAS HORIZONTAL ══════════════ -->
    <summary>
        <band height="240" splitType="Stretch">
            <staticText>
                <reportElement x="0" y="8" width="802" height="22" forecolor="#1A3A5C" uuid="c1a2b3d4-e5f6-7890-abcd-ef1234567831"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font fontName="DejaVu Sans" size="13" isBold="true"/>
                </textElement>
                <text><![CDATA[Comparativa de ingresos por empleado]]></text>
            </staticText>
            <bar3DChart>
                <chart evaluationTime="Report" theme="default">
                    <reportElement x="0" y="34" width="802" height="200" uuid="c1a2b3d4-e5f6-7890-abcd-ef1234567832"/>
                    <chartTitle position="Top">
                        <titleExpression><![CDATA[""]]></titleExpression>
                    </chartTitle>
                    <chartSubtitle/>
                    <chartLegend position="Bottom" textColor="#2D3A2E">
                        <font fontName="DejaVu Sans" size="9"/>
                    </chartLegend>
                </chart>
                <categoryDataset>
                    <categorySeries>
                        <seriesExpression><![CDATA["Ingresos"]]></seriesExpression>
                        <categoryExpression><![CDATA[$F{nombre_empleado} + " " + $F{apellido}]]></categoryExpression>
                        <valueExpression><![CDATA[$F{total_ingresos}]]></valueExpression>
                    </categorySeries>
                </categoryDataset>
                <bar3DPlot isShowLabels="true">
                    <plot>
                        <seriesColor seriesOrder="0" color="#1E5799"/>
                        <seriesColor seriesOrder="1" color="#4A90D9"/>
                        <seriesColor seriesOrder="2" color="#A8C8F0"/>
                        <seriesColor seriesOrder="3" color="#1A3A5C"/>
                        <seriesColor seriesOrder="4" color="#6BAED6"/>
                    </plot>
                    <itemLabel color="#1A3A5C">
                        <font fontName="DejaVu Sans" size="9" isBold="true"/>
                    </itemLabel>
                    <categoryAxisFormat>
                        <axisFormat tickLabelColor="#2D3A2E" axisLineColor="#1E5799">
                            <labelFont><font fontName="DejaVu Sans" size="9" isBold="true"/></labelFont>
                            <tickLabelFont><font fontName="DejaVu Sans" size="8"/></tickLabelFont>
                        </axisFormat>
                    </categoryAxisFormat>
                    <valueAxisFormat>
                        <axisFormat tickLabelColor="#2D3A2E" tickLabelMask="$#,##0.00" axisLineColor="#1E5799">
                            <labelFont><font fontName="DejaVu Sans" size="9" isBold="true"/></labelFont>
                            <tickLabelFont><font fontName="DejaVu Sans" size="8"/></tickLabelFont>
                        </axisFormat>
                    </valueAxisFormat>
                </bar3DPlot>
            </bar3DChart>
        </band>
    </summary>

