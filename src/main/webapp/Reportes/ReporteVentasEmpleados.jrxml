                <text><![CDATA[Total Ingresos ($)]]></text>
            </staticText>
        </band>
    </columnHeader>

    <!-- ══════════════ DETAIL ══════════════ -->
    <detail>
        <band height="34" splitType="Stretch">
            <!-- Fila par -->
            <rectangle>
                <reportElement x="0" y="0" width="802" height="34" backcolor="#D6E8F7" forecolor="#D6E8F7" uuid="c1a2b3d4-e5f6-7890-abcd-ef1234567814">
                    <printWhenExpression><![CDATA[$V{REPORT_COUNT} % 2 == 0]]></printWhenExpression>
                </reportElement>
                <graphicElement><pen lineWidth="0"/></graphicElement>
            </rectangle>
            <!-- Fila impar -->
            <rectangle>
                <reportElement x="0" y="0" width="802" height="34" backcolor="#EDF4FB" forecolor="#EDF4FB" uuid="c1a2b3d4-e5f6-7890-abcd-ef1234567815">
                    <printWhenExpression><![CDATA[$V{REPORT_COUNT} % 2 != 0]]></printWhenExpression>
                </reportElement>
                <graphicElement><pen lineWidth="0"/></graphicElement>
            </rectangle>
            <line>
                <reportElement x="0" y="33" width="802" height="1" forecolor="#A8C8F0" uuid="c1a2b3d4-e5f6-7890-abcd-ef1234567816"/>
            </line>
            <!-- Nombre empleado -->
            <textField>
                <reportElement x="10" y="0" width="220" height="34" style="dato_texto" uuid="c1a2b3d4-e5f6-7890-abcd-ef1234567817"/>
                <textElement verticalAlignment="Middle">
                    <font fontName="DejaVu Sans" size="11"/>
                </textElement>
                <textFieldExpression><![CDATA[$F{nombre_empleado} + " " + $F{apellido}]]></textFieldExpression>
            </textField>
            <line>
                <reportElement x="230" y="4" width="1" height="26" forecolor="#A8C8F0" uuid="c1a2b3d4-e5f6-7890-abcd-ef1234567818"/>
            </line>
            <!-- Rol -->
            <textField>
                <reportElement x="240" y="0" width="180" height="34" style="dato_texto" uuid="c1a2b3d4-e5f6-7890-abcd-ef1234567819"/>
                <textElement verticalAlignment="Middle">
                    <font fontName="DejaVu Sans" size="11"/>
                </textElement>
                <textFieldExpression><![CDATA[$F{rol}]]></textFieldExpression>
            </textField>
            <line>
                <reportElement x="420" y="4" width="1" height="26" forecolor="#A8C8F0" uuid="c1a2b3d4-e5f6-7890-abcd-ef1234567820"/>
            </line>
            <!-- Total ventas -->
            <textField>
                <reportElement x="430" y="0" width="170" height="34" style="dato_numero" uuid="c1a2b3d4-e5f6-7890-abcd-ef1234567821"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font fontName="DejaVu Sans" size="11" isBold="true"/>
                </textElement>
                <textFieldExpression><![CDATA[$F{total_ventas}]]></textFieldExpression>
            </textField>
            <line>
                <reportElement x="600" y="4" width="1" height="26" forecolor="#A8C8F0" uuid="c1a2b3d4-e5f6-7890-abcd-ef1234567822"/>
            </line>
            <!-- Total ingresos -->
            <textField pattern="$#,##0.00">
                <reportElement x="610" y="0" width="182" height="34" style="dato_numero" uuid="c1a2b3d4-e5f6-7890-abcd-ef1234567823"/>
                <textElement textAlignment="Right" verticalAlignment="Middle">
                    <font fontName="DejaVu Sans" size="11" isBold="true"/>
                </textElement>
                <textFieldExpression><![CDATA[$F{total_ingresos}]]></textFieldExpression>
            </textField>
        </band>
    </detail>

