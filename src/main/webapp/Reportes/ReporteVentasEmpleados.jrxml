            </line>
            <staticText>
                <reportElement x="240" y="0" width="180" height="36" style="encabezado_col" uuid="c1a2b3d4-e5f6-7890-abcd-ef1234567809"/>
                <textElement verticalAlignment="Middle">
                    <font fontName="DejaVu Sans" size="11" isBold="true"/>
                </textElement>
                <text><![CDATA[Rol]]></text>
            </staticText>
            <line>
                <reportElement x="420" y="6" width="1" height="24" forecolor="#4A90D9" uuid="c1a2b3d4-e5f6-7890-abcd-ef1234567810"/>
            </line>
            <staticText>
