                <graphicElement><pen lineWidth="0"/></graphicElement>
            </rectangle>
            <staticText>
                <reportElement x="10" y="0" width="220" height="36" style="encabezado_col" uuid="c1a2b3d4-e5f6-7890-abcd-ef1234567807"/>
