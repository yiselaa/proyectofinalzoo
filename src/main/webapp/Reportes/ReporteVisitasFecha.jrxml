<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
              xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
              name="ReporteVisitasFecha"
              pageWidth="842" pageHeight="595"
              orientation="Landscape"
              columnWidth="802"
              leftMargin="20" rightMargin="20"
              topMargin="20" bottomMargin="20"
              uuid="d94e2b17-3c8a-4f1b-b6e0-12345678abcd">

    <property name="com.jaspersoft.studio.data.sql.tables" value=""/>
    <property name="com.jaspersoft.studio.data.defaultdataadapter" value="BaseZoo"/>

    <style name="encabezado_col" fontName="DejaVu Sans" fontSize="11" isBold="true" forecolor="#FFFFFF"/>
    <style name="dato_texto"     fontName="DejaVu Sans" fontSize="11"               forecolor="#2D3A2E"/>
    <style name="dato_numero"    fontName="DejaVu Sans" fontSize="11" isBold="true" forecolor="#6B2D0E"/>
    <style name="footer_texto"   fontName="DejaVu Sans" fontSize="9"                forecolor="#74857A"/>

    <queryString language="SQL">
        <![CDATA[SELECT
    fecha_visita,
    COUNT(id)     AS total_visitas,
    SUM(subtotal) AS total_ingresos
FROM public.visita
GROUP BY fecha_visita
ORDER BY fecha_visita ASC]]>
    </queryString>

    <field name="fecha_visita"    class="java.sql.Date"/>
    <field name="total_visitas"   class="java.lang.Long"/>
    <field name="total_ingresos"  class="java.lang.Double"/>

    <variable name="GRAND_VISITAS" class="java.lang.Long" calculation="Sum">
        <variableExpression><![CDATA[$F{total_visitas}]]></variableExpression>
    </variable>
    <variable name="GRAND_INGRESOS" class="java.lang.Double" calculation="Sum">
        <variableExpression><![CDATA[$F{total_ingresos}]]></variableExpression>
    </variable>

    <background>
        <band splitType="Stretch"/>
    </background>

    <!-- ══════════════ TITLE ══════════════ -->
    <title>
        <band height="90" splitType="Stretch">
            <!-- Fondo naranja oscuro -->
            <rectangle>
                <reportElement x="0" y="0" width="802" height="90" backcolor="#7B2D00" forecolor="#7B2D00" uuid="aa000001-0000-0000-0000-000000000001"/>
                <graphicElement><pen lineWidth="0"/></graphicElement>
            </rectangle>
            <!-- Acento lateral naranja claro -->
            <rectangle>
                <reportElement x="0" y="0" width="5" height="90" backcolor="#E8713C" forecolor="#E8713C" uuid="aa000001-0000-0000-0000-000000000002"/>
                <graphicElement><pen lineWidth="0"/></graphicElement>
            </rectangle>
            <!-- Título -->
            <staticText>
                <reportElement x="18" y="10" width="600" height="38" forecolor="#FFFFFF" uuid="aa000001-0000-0000-0000-000000000003"/>
                <textElement verticalAlignment="Middle">
                    <font fontName="DejaVu Sans" size="26" isBold="true"/>
                </textElement>
                <text><![CDATA[WILD ZOO MK]]></text>
            </staticText>
            <!-- Subtítulo -->
            <staticText>
                <reportElement x="18" y="52" width="600" height="22" forecolor="#F4B48A" uuid="aa000001-0000-0000-0000-000000000004"/>
                <textElement verticalAlignment="Middle">
                    <font fontName="DejaVu Sans" size="12"/>
                </textElement>
                <text><![CDATA[Reporte de visitas por fecha]]></text>
            </staticText>
            <!-- Fecha generación -->
            <textField>
                <reportElement x="560" y="36" width="240" height="18" forecolor="#F4B48A" uuid="aa000001-0000-0000-0000-000000000005"/>
                <textElement textAlignment="Right" verticalAlignment="Middle">
                    <font fontName="DejaVu Sans" size="9"/>
                </textElement>
                <textFieldExpression><![CDATA["Generado: " + new java.text.SimpleDateFormat("dd/MM/yyyy h:mma", java.util.Locale.ENGLISH).format(new java.util.Date())]]></textFieldExpression>
            </textField>
        </band>
    </title>

    <pageHeader>
        <band height="8" splitType="Stretch"/>
    </pageHeader>

    <!-- ══════════════ COLUMN HEADER ══════════════ -->
    <columnHeader>
        <band height="36" splitType="Stretch">
            <rectangle>
                <reportElement x="0" y="0" width="802" height="36" backcolor="#C0440A" forecolor="#C0440A" uuid="aa000001-0000-0000-0000-000000000006"/>
                <graphicElement><pen lineWidth="0"/></graphicElement>
            </rectangle>
            <staticText>
                <reportElement x="10" y="0" width="300" height="36" style="encabezado_col" uuid="aa000001-0000-0000-0000-000000000007"/>
                <textElement verticalAlignment="Middle">
                    <font fontName="DejaVu Sans" size="11" isBold="true"/>
                </textElement>
                <text><![CDATA[Fecha de visita]]></text>
            </staticText>
            <line>
                <reportElement x="310" y="6" width="1" height="24" forecolor="#E8713C" uuid="aa000001-0000-0000-0000-000000000008"/>
            </line>
            <staticText>
                <reportElement x="320" y="0" width="230" height="36" style="encabezado_col" uuid="aa000001-0000-0000-0000-000000000009"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font fontName="DejaVu Sans" size="11" isBold="true"/>
                </textElement>
                <text><![CDATA[Total de visitas]]></text>
            </staticText>
            <line>
                <reportElement x="550" y="6" width="1" height="24" forecolor="#E8713C" uuid="aa000001-0000-0000-0000-000000000010"/>
            </line>
            <staticText>
                <reportElement x="560" y="0" width="232" height="36" style="encabezado_col" uuid="aa000001-0000-0000-0000-000000000011"/>
                <textElement textAlignment="Right" verticalAlignment="Middle">
                    <font fontName="DejaVu Sans" size="11" isBold="true"/>
                </textElement>
                <text><![CDATA[Total ingresos ($)]]></text>
            </staticText>
        </band>
    </columnHeader>

    <!-- ══════════════ DETAIL ══════════════ -->
    <detail>
        <band height="34" splitType="Stretch">
            <!-- Fila par -->
            <rectangle>
                <reportElement x="0" y="0" width="802" height="34" backcolor="#FDDEC8" forecolor="#FDDEC8" uuid="aa000001-0000-0000-0000-000000000012">
                    <printWhenExpression><![CDATA[$V{REPORT_COUNT} % 2 == 0]]></printWhenExpression>
                </reportElement>
                <graphicElement><pen lineWidth="0"/></graphicElement>
            </rectangle>
            <!-- Fila impar -->
            <rectangle>
                <reportElement x="0" y="0" width="802" height="34" backcolor="#FEF0E6" forecolor="#FEF0E6" uuid="aa000001-0000-0000-0000-000000000013">
                    <printWhenExpression><![CDATA[$V{REPORT_COUNT} % 2 != 0]]></printWhenExpression>
                </reportElement>
                <graphicElement><pen lineWidth="0"/></graphicElement>
            </rectangle>
            <line>
                <reportElement x="0" y="33" width="802" height="1" forecolor="#F4B48A" uuid="aa000001-0000-0000-0000-000000000014"/>
            </line>
            <!-- Fecha -->
            <textField pattern="dd/MM/yyyy">
                <reportElement x="10" y="0" width="300" height="34" style="dato_texto" uuid="aa000001-0000-0000-0000-000000000015"/>
                <textElement verticalAlignment="Middle">
                    <font fontName="DejaVu Sans" size="11"/>
                </textElement>
                <textFieldExpression><![CDATA[$F{fecha_visita}]]></textFieldExpression>
            </textField>
            <line>
                <reportElement x="310" y="4" width="1" height="26" forecolor="#F4B48A" uuid="aa000001-0000-0000-0000-000000000016"/>
            </line>
            <!-- Total visitas -->
            <textField>
                <reportElement x="320" y="0" width="230" height="34" style="dato_numero" uuid="aa000001-0000-0000-0000-000000000017"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font fontName="DejaVu Sans" size="11" isBold="true"/>
                </textElement>
                <textFieldExpression><![CDATA[$F{total_visitas}]]></textFieldExpression>
            </textField>
            <line>
                <reportElement x="550" y="4" width="1" height="26" forecolor="#F4B48A" uuid="aa000001-0000-0000-0000-000000000018"/>
            </line>
            <!-- Total ingresos -->
            <textField pattern="$#,##0.00">
                <reportElement x="560" y="0" width="232" height="34" style="dato_numero" uuid="aa000001-0000-0000-0000-000000000019"/>
                <textElement textAlignment="Right" verticalAlignment="Middle">
                    <font fontName="DejaVu Sans" size="11" isBold="true"/>
                </textElement>
                <textFieldExpression><![CDATA[$F{total_ingresos}]]></textFieldExpression>
            </textField>
        </band>
    </detail>

    <!-- ══════════════ COLUMN FOOTER ══════════════ -->
    <columnFooter>
        <band height="36" splitType="Stretch">
            <line>
                <reportElement x="0" y="0" width="802" height="1" forecolor="#C0440A" uuid="aa000001-0000-0000-0000-000000000020"/>
            </line>
            <staticText>
                <reportElement x="10" y="6" width="310" height="24" forecolor="#7B2D00" uuid="aa000001-0000-0000-0000-000000000021"/>
                <textElement verticalAlignment="Middle">
                    <font fontName="DejaVu Sans" size="11" isBold="true"/>
                </textElement>
                <text><![CDATA[TOTAL GENERAL]]></text>
            </staticText>
            <textField>
                <reportElement x="320" y="6" width="230" height="24" forecolor="#7B2D00" uuid="aa000001-0000-0000-0000-000000000022"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font fontName="DejaVu Sans" size="12" isBold="true"/>
                </textElement>
                <textFieldExpression><![CDATA[$V{GRAND_VISITAS}]]></textFieldExpression>
            </textField>
            <textField pattern="$#,##0.00">
                <reportElement x="560" y="6" width="232" height="24" forecolor="#7B2D00" uuid="aa000001-0000-0000-0000-000000000023"/>
                <textElement textAlignment="Right" verticalAlignment="Middle">
                    <font fontName="DejaVu Sans" size="13" isBold="true"/>
                </textElement>
                <textFieldExpression><![CDATA[$V{GRAND_INGRESOS}]]></textFieldExpression>
            </textField>
        </band>
    </columnFooter>

    <!-- ══════════════ PAGE FOOTER ══════════════ -->
    <pageFooter>
        <band height="28" splitType="Stretch">
            <line>
                <reportElement x="0" y="0" width="802" height="1" forecolor="#F4B48A" uuid="aa000001-0000-0000-0000-000000000024"/>
            </line>
            <staticText>
                <reportElement x="0" y="5" width="400" height="18" style="footer_texto" uuid="aa000001-0000-0000-0000-000000000025"/>
                <textElement verticalAlignment="Middle">
                    <font fontName="DejaVu Sans" size="9"/>
                </textElement>
                <text><![CDATA[© Wild Zoo MK — Reporte de visitas por fecha]]></text>
            </staticText>
            <textField>
                <reportElement x="402" y="5" width="400" height="18" style="footer_texto" uuid="aa000001-0000-0000-0000-000000000026"/>
                <textElement textAlignment="Right" verticalAlignment="Middle">
                    <font fontName="DejaVu Sans" size="9"/>
                </textElement>
                <textFieldExpression><![CDATA["Página " + $V{PAGE_NUMBER}]]></textFieldExpression>
            </textField>
        </band>
    </pageFooter>

    <!-- ══════════════ SUMMARY: GRÁFICO DE LÍNEAS ══════════════ -->
    <summary>
        <band height="240" splitType="Stretch">
            <staticText>
                <reportElement x="0" y="8" width="802" height="22" forecolor="#7B2D00" uuid="aa000001-0000-0000-0000-000000000027"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font fontName="DejaVu Sans" size="13" isBold="true"/>
                </textElement>
                <text><![CDATA[Tendencia de ingresos por fecha]]></text>
            </staticText>
            <lineChart>
                <chart evaluationTime="Report" theme="default">
                    <reportElement x="0" y="34" width="802" height="200" uuid="aa000001-0000-0000-0000-000000000028"/>
                    <chartTitle position="Top">
                        <titleExpression><![CDATA[""]]></titleExpression>
                    </chartTitle>
                    <chartSubtitle/>
                    <chartLegend position="Bottom" textColor="#2D3A2E">
                        <font fontName="DejaVu Sans" size="9"/>
                    </chartLegend>
                </chart>
                <categoryDataset>
                    <categorySeries>
                        <seriesExpression><![CDATA["Ingresos"]]></seriesExpression>
                        <categoryExpression><![CDATA[new java.text.SimpleDateFormat("dd/MM/yyyy").format($F{fecha_visita})]]></categoryExpression>
                        <valueExpression><![CDATA[$F{total_ingresos}]]></valueExpression>
                    </categorySeries>
                    <categorySeries>
                        <seriesExpression><![CDATA["Visitas"]]></seriesExpression>
                        <categoryExpression><![CDATA[new java.text.SimpleDateFormat("dd/MM/yyyy").format($F{fecha_visita})]]></categoryExpression>
                        <valueExpression><![CDATA[$F{total_visitas}.doubleValue()]]></valueExpression>
                    </categorySeries>
                </categoryDataset>
                <linePlot isShowShapes="true" isShowLines="true">
                    <plot>
                        <seriesColor seriesOrder="0" color="#C0440A"/>
                        <seriesColor seriesOrder="1" color="#E8713C"/>
                    </plot>
                    <categoryAxisFormat>
                        <axisFormat tickLabelColor="#2D3A2E" axisLineColor="#C0440A">
                            <labelFont><font fontName="DejaVu Sans" size="9" isBold="true"/></labelFont>
                            <tickLabelFont><font fontName="DejaVu Sans" size="7"/></tickLabelFont>
                        </axisFormat>
                    </categoryAxisFormat>
                    <valueAxisFormat>
                        <axisFormat tickLabelColor="#2D3A2E" tickLabelMask="#,##0.00" axisLineColor="#C0440A">
                            <labelFont><font fontName="DejaVu Sans" size="9" isBold="true"/></labelFont>
                            <tickLabelFont><font fontName="DejaVu Sans" size="8"/></tickLabelFont>
                        </axisFormat>
                    </valueAxisFormat>
                </linePlot>
            </lineChart>
        </band>
    </summary>

</jasperReport>
