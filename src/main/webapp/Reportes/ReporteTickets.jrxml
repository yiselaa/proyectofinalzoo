	<queryString language="SQL">
		<![CDATA[SELECT
    t.tipo AS tipo_ticket,
    SUM(dv.subtotal) AS total_ingresos
FROM public.visita dv
JOIN public.ticket t ON dv.idticket = t.id
GROUP BY t.tipo
ORDER BY total_ingresos DESC]]>
	</queryString>
	<field name="tipo_ticket" class="java.lang.String"/>
	<field name="total_ingresos" class="java.lang.Double"/>
	<variable name="GRAND_TOTAL" class="java.lang.Double" calculation="Sum">
		<variableExpression><![CDATA[$F{total_ingresos}]]></variableExpression>
	</variable>
